name: Post to Facebook

on:
  schedule:
    - cron: '*/30 * * * *'     # every 30 minutes
  workflow_dispatch:

jobs:
  post:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      
      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'
      
      - name: Install dependencies
        run: |
          pip install requests google-api-python-client google-auth google-auth-oauthlib
      
      - name: Run Facebook Poster
        env:
          GITHUB_RUN_ID: ${{ github.run_id }}
          UPLOAD_FOLDER_ID: ${{ secrets.UPLOAD_FOLDER_ID }}
          PROCESSED_FOLDER_ID: ${{ secrets.PROCESSED_FOLDER_ID }}
          # Add any other secrets you need
        run: python main.py
